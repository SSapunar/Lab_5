<h1>Owners</h1>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Pets</th>
    </tr>
  </thead>

  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td>
          <%= link_to "#{owner.first_name} #{owner.last_name}", owner %>
        </td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td><%= owner.pets.count %></td>
      </tr>
    <% end %>
  </tbody>
</table>