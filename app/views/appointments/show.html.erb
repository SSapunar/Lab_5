<h1>Appointment Details</h1>

<p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") %></p>
<p><strong>Reason:</strong> <%= @appointment.reason %></p>
<p><strong>Status:</strong> <%= @appointment.status %></p>

<p>
  <strong>Pet:</strong>
  <%= link_to @appointment.pet.name, @appointment.pet %>
</p>

<p>
  <strong>Vet:</strong>
  <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", @appointment.vet %>
</p>

<h2>Treatments</h2>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Medication</th>
      <th>Dosage</th>
      <th>Administered At</th>
      <th>Notes</th>
    </tr>
  </thead>

  <tbody>
    <% @appointment.treatments.each do |treatment| %>
      <tr>
        <td><%= treatment.name %></td>
        <td><%= treatment.medication %></td>
        <td><%= treatment.dosage %></td>
        <td><%= treatment.administered_at %></td>
        <td><%= treatment.notes %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back", appointments_path, class: "btn btn-secondary" %>