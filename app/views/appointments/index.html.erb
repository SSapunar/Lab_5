<h1>Appointments</h1>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>

  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td>
          <%= link_to appointment.date.strftime("%B %d, %Y"), appointment %>
        </td>
        <td><%= link_to appointment.pet.name, appointment.pet %></td>
        <td>
          <%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", appointment.vet %>
        </td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>